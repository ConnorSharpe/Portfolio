---
---

<!-- Chat bubble trigger -->
<button
  id="chat-bubble"
  aria-label="Open chat"
  aria-expanded="false"
  aria-controls="chat-panel"
  class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full bg-accent text-white shadow-lg flex items-center justify-center hover:scale-105 transition-transform focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary"
>
  <svg id="chat-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-3 3v-3z" />
  </svg>
  <svg id="chat-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
  </svg>
</button>

<!-- Chat panel -->
<div
  id="chat-panel"
  role="dialog"
  aria-label="Chat with Connor's AI assistant"
  aria-modal="true"
  class="fixed bottom-24 right-6 z-50 w-[380px] max-w-[calc(100vw-1.5rem)] rounded-xl shadow-2xl border border-border bg-bg-primary flex flex-col overflow-hidden transition-all duration-200 opacity-0 translate-y-4 pointer-events-none"
  style="max-height: 500px;"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-4 py-3 border-b border-border bg-bg-secondary">
    <div>
      <p class="text-sm font-semibold text-text-primary">Ask me about Connor</p>
      <p class="text-xs text-text-muted">AI assistant · answers from portfolio</p>
    </div>
    <button
      id="chat-close-btn"
      aria-label="Close chat"
      class="text-text-muted hover:text-text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-accent rounded"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Message list -->
  <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3 text-sm" aria-live="polite" aria-atomic="false">
    <div class="flex justify-start">
      <div class="max-w-[80%] rounded-lg px-3 py-2 bg-bg-secondary text-text-primary">
        Hey — I can answer questions about Connor's work, skills, and experience. What do you want to know?
      </div>
    </div>
  </div>

  <!-- Input row -->
  <div class="px-3 py-3 border-t border-border bg-bg-secondary">
    <div id="usage-limit-msg" class="hidden text-xs text-text-muted text-center pb-2">
      You've reached the 5 message limit for this session.
    </div>
    <div class="flex gap-2">
      <input
        id="chat-input"
        type="text"
        maxlength="500"
        placeholder="Ask something…"
        autocomplete="off"
        class="flex-1 rounded-lg px-3 py-2 text-sm bg-bg-primary border border-border text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent disabled:opacity-50"
        aria-label="Your message"
      />
      <button
        id="chat-send"
        aria-label="Send message"
        class="px-3 py-2 rounded-lg bg-accent text-white text-sm font-medium hover:opacity-90 transition-opacity disabled:opacity-40 focus:outline-none focus:ring-2 focus:ring-accent"
      >
        Send
      </button>
    </div>
  </div>
</div>

<script>
  const USAGE_LIMIT = 5;
  const STORAGE_KEY = 'chat_usage_count';

  const bubble = document.getElementById('chat-bubble') as HTMLButtonElement;
  const panel = document.getElementById('chat-panel') as HTMLDivElement;
  const closeBtn = document.getElementById('chat-close-btn') as HTMLButtonElement;
  const messages = document.getElementById('chat-messages') as HTMLDivElement;
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
  const usageLimitMsg = document.getElementById('usage-limit-msg') as HTMLDivElement;
  const iconOpen = document.getElementById('chat-icon-open') as SVGElement;
  const iconClose = document.getElementById('chat-icon-close') as SVGElement;

  let isOpen = false;
  let isLoading = false;

  function getUsageCount(): number {
    return parseInt(sessionStorage.getItem(STORAGE_KEY) ?? '0', 10);
  }

  function incrementUsage(): void {
    sessionStorage.setItem(STORAGE_KEY, String(getUsageCount() + 1));
  }

  function checkUsageLimit(): void {
    if (getUsageCount() >= USAGE_LIMIT) {
      input.disabled = true;
      sendBtn.disabled = true;
      usageLimitMsg.classList.remove('hidden');
    }
  }

  function openPanel(): void {
    isOpen = true;
    panel.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
    panel.classList.add('opacity-100', 'translate-y-0');
    bubble.setAttribute('aria-expanded', 'true');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
    checkUsageLimit();
    if (!input.disabled) input.focus();
  }

  function closePanel(): void {
    isOpen = false;
    panel.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
    panel.classList.remove('opacity-100', 'translate-y-0');
    bubble.setAttribute('aria-expanded', 'false');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
    bubble.focus();
  }

  function appendMessage(text: string, role: 'user' | 'assistant'): void {
    const wrapper = document.createElement('div');
    wrapper.className = `flex ${role === 'user' ? 'justify-end' : 'justify-start'}`;

    const bubble = document.createElement('div');
    bubble.className = [
      'max-w-[80%] rounded-lg px-3 py-2',
      role === 'user'
        ? 'bg-accent text-white'
        : 'bg-bg-secondary text-text-primary',
    ].join(' ');
    bubble.textContent = text;

    wrapper.appendChild(bubble);
    messages.appendChild(wrapper);
    messages.scrollTop = messages.scrollHeight;
  }

  function setLoading(loading: boolean): void {
    isLoading = loading;
    input.disabled = loading || getUsageCount() >= USAGE_LIMIT;
    sendBtn.disabled = loading || getUsageCount() >= USAGE_LIMIT;
    if (loading) {
      sendBtn.textContent = 'Thinking…';
    } else {
      sendBtn.textContent = 'Send';
    }
  }

  async function sendMessage(): Promise<void> {
    const text = input.value.trim();
    if (!text || isLoading) return;
    if (getUsageCount() >= USAGE_LIMIT) return;

    input.value = '';
    appendMessage(text, 'user');
    setLoading(true);
    incrementUsage();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text }),
        signal: AbortSignal.timeout(12_000),
      });

      const data = await res.json() as { reply?: string; error?: string };

      if (data.reply) {
        appendMessage(data.reply, 'assistant');
      } else if (data.error === 'Request timed out') {
        appendMessage('Request timed out — try again.', 'assistant');
      } else {
        appendMessage('Something went wrong — try again.', 'assistant');
      }
    } catch (err: unknown) {
      const error = err as Error;
      if (error.name === 'TimeoutError' || error.name === 'AbortError') {
        appendMessage('Request timed out — try again.', 'assistant');
      } else {
        appendMessage('Something went wrong — try again.', 'assistant');
      }
    } finally {
      setLoading(false);
      checkUsageLimit();
      if (!input.disabled) input.focus();
    }
  }

  bubble.addEventListener('click', () => (isOpen ? closePanel() : openPanel()));
  closeBtn.addEventListener('click', closePanel);

  sendBtn.addEventListener('click', sendMessage);
  input.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') sendMessage();
  });

  // Escape closes panel; trap focus inside when open
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && isOpen) {
      closePanel();
      return;
    }

    if (!isOpen || e.key !== 'Tab') return;

    const focusable = panel.querySelectorAll<HTMLElement>(
      'button:not([disabled]), input:not([disabled])'
    );
    if (focusable.length === 0) return;

    const first = focusable[0];
    const last = focusable[focusable.length - 1];

    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
    } else {
      if (document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });
</script>
