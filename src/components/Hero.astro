---
---

<section
  id="hero"
  class="min-h-[calc(100vh-4rem)] flex items-center py-20 px-4 sm:px-6"
  aria-label="Introduction"
>
  <div class="max-w-6xl mx-auto w-full">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Photo -->
      <div class="order-1 md:order-none flex justify-center md:justify-start">
        <div class="relative">
          <!-- Accent ring behind photo -->
          <div
            class="absolute -inset-1 rounded-full bg-gradient-to-br from-accent to-accent-warm opacity-30 blur-md"
            aria-hidden="true"
          >
          </div>
          <img
            src="/images/Portfolio_Profile_Pic.png"
            alt="Connor Sharpe"
            width="280"
            height="280"
            class="relative rounded-full object-cover w-48 h-48 sm:w-56 sm:h-56 md:w-64 md:h-64 border-2 border-border"
            loading="eager"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="order-first md:order-none text-center md:text-left">
        <p class="font-mono text-accent text-sm mb-3 tracking-widest uppercase">
          Available for senior engineering roles
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-text-primary leading-tight mb-4">
          Connor Sharpe
        </h1>
        <p class="text-lg sm:text-xl text-accent font-semibold mb-6">
          AI Engineer&nbsp;&middot;&nbsp;Full-Stack Developer
        </p>
        <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-8 max-w-lg mx-auto md:mx-0">
          I build things that work, ship things that matter, and occasionally write code
          comments so good they could be poems. Currently thinking hard about how to make
          AI agents less annoying.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start">
          <a
            href="#contact"
            class="px-6 py-3 bg-accent text-bg font-semibold rounded-lg hover:bg-accent/90 transition-colors text-center"
          >
            Get In Touch
          </a>
          <a
            href="/resume/Sharpe_AI_Resume_2026.pdf"
            download
            class="px-6 py-3 border border-border text-text-primary font-semibold rounded-lg hover:border-accent hover:text-accent transition-colors text-center"
          >
            Download Resume
          </a>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-4 mt-8 justify-center md:justify-start">
          <a
            href="https://github.com/ConnorSharpe"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Connor Sharpe on GitHub"
            class="text-text-muted hover:text-text-primary transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
          </a>
          <a
            href="https://linkedin.com/in/connorsharpe92"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Connor Sharpe on LinkedIn"
            class="text-text-muted hover:text-text-primary transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
          <a
            href="mailto:connor.sharpe92@gmail.com"
            aria-label="Email Connor Sharpe"
            class="text-text-muted hover:text-text-primary transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
